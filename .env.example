# BibleVoice (God AI) environment
# Copy to .env and fill in. NEVER commit the real .env.

# Anthropic API — dedicated pay-as-you-go key (NOT a Claude subscription).
# Customer-facing chat/voice must run on a metered API key per Anthropic's terms.
ANTHROPIC_API_KEY=

# Model for the chat/voice agent. Keep it cheap for a free public app.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Server
PORT=3000
